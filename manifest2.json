{
  "extension": {
    "name": "Dynamic Object Deployer",
    "description": "Deploys the auto-update script to Gaia Embedded gateways.",
    "version": "1.0",
    "provider": "Ivan LWDC",
    "product-url": "https://ivanlwdc.github.io/publictools/"
  },
  "extension-version-requirements": {
    "minimum-version": "1.1"
  },
  "locations": [
    {
      "location": "context-menu",
      "relevant-types": [
        "gateway"
      ],
      "ui-element": {
        "caption": "Deploy Dynamic Object Script",
        "action": {
          "trigger-id": "deploy-script-action",
          "url": "https://ivanlwdc.github.io/publictools/index.html",
          "browser-window": {
            "width": 800,
            "height": 600
          }
        }
      }
    }
  ]
}
