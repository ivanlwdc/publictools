{
  "extension": {
    "name": "Dynamic Object Deployer",
    "description": "Deploys the Dynamic Object auto-update script to Gaia Embedded gateways.",
    "version": "1.0",
    "provider": "Ivan WDC",
    "product-url": "https://ivanlwdc.github.io/publictools/",
    "extension-version-requirements": {
      "minimum-version": "1.1"
    },
    "locations": [
      {
        "location": "toolbar",
        "relevant-types": [
          "gateways"
        ],
        "ui-element": {
          "caption": "Deploy Dynamic Object Script",
          "action": {
            "url": "https://ivanlwdc.github.io/publictools/index.html",
            "browser-window": {
              "width": "800",
              "height": "600"
            }
          }
        }
      }
    ]
  }
}
